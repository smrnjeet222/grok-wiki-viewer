# Optional build-time config for the static frontend.

# Point the static site at a remote Grok-Wiki API (HTTPS tunnel or VPS).
# Must include the /api suffix. Leave unset to use the same-origin `/api`.
# VITE_API_BASE=https://your-tunnel.example/api

# Deploy under a subpath (e.g. GitHub Pages project site). Include trailing slash.
# VITE_BASE=/local-wiki-preview/
